{
  "title": "🍅 Tomato AI - Executive Command Center",
  "panels": [
    {
      "title": "TOTAL REQUESTS",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(tomato_uploads_total) or vector(0)" }],
      "fieldConfig": { 
        "defaults": { "min": 0, "max": 500, "thresholds": { "steps": [{ "color": "green", "value": null }] } } 
      }
    },
    {
      "title": "A/B TEST: RESNET50",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "sum(tomato_disease_predictions_total{model_variant=\"resnet\"}) or vector(0)" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 250, "fixedColor": "blue" } }
    },
    {
      "title": "A/B TEST: EFFICIENTNET",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "sum(tomato_disease_predictions_total{model_variant=\"efficient\"}) or vector(0)" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 250, "fixedColor": "orange" } }
    },
    {
      "title": "GATEKEEPER RATIO",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum by (status) (tomato_gatekeeper_checks_total)" }]
    },
    {
      "title": "BRIGHTNESS DEVIATION",
      "type": "gauge",
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 8 },
      "description": "0% = Perfect Match. Positive = Too Bright | Negative = Too Dark",
      "targets": [{ 
        "expr": "max(tomato_drift_percentage{drift_type=\"drift_brightness_pct\"})" 
      }],
      "fieldConfig": {
        "defaults": {
          "min": -50,
          "max": 50,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": -20 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "CONTRAST DEVIATION",
      "type": "gauge",
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 8 },
      "description": "0% = Perfect Match. Positive = Too Harsh | Negative = Too Blurry",
      "targets": [{ 
        "expr": "max(tomato_drift_percentage{drift_type=\"drift_contrast_pct\"})" 
      }],
      "fieldConfig": {
        "defaults": {
          "min": -50,
          "max": 50,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": -25 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38
}